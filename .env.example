# ── Segurança ──────────────────────────────────────────────────────────────────
# Gere um JWT_SECRET forte: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=

# ── Admin padrão ───────────────────────────────────────────────────────────────
# Use uma senha forte (mínimo 12 chars, maiúscula, número, especial)
ADMIN_EMAIL=admin@gostate.dev
ADMIN_PASSWORD=

# ── Token do agente ────────────────────────────────────────────────────────────
# Gere um token forte: node -e "const {v4}=require('uuid'); console.log(v4()+'-'+v4())"
# Ou: node -e "const c=require('crypto'); console.log('gst_'+c.randomBytes(16).toString('hex')+'-'+c.randomBytes(16).toString('hex'))"
DEFAULT_AGENT_TOKEN=

# ── URLs ───────────────────────────────────────────────────────────────────────
# URL externa (usada pelo browser para chamar a API)
VITE_API_BASE=http://localhost:4000
# URL interna (usada pelo agente dentro do Docker para conectar ao backend)
INTERNAL_BACKEND_URL=http://backend:4000
# CORS: URL que o browser usa para acessar o frontend
CORS_ORIGIN=http://localhost:5173

# ── Agente ─────────────────────────────────────────────────────────────────────
AGENT_MAX_CONCURRENT=3
TZ=America/Sao_Paulo

# ── Artefatos ──────────────────────────────────────────────────────────────────
ARTIFACT_RETENTION_DAYS=30
