# ─── Servidor ─────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ─── Segurança (OBRIGATÓRIO em produção) ──────────────────────────────────────
# Gere com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change-me-in-production

# ─── CORS ─────────────────────────────────────────────────────────────────────
# URL do frontend. Use '*' apenas em desenvolvimento local.
CORS_ORIGIN=http://localhost:5173

# ─── Banco de dados e artefatos ───────────────────────────────────────────────
DB_PATH=./data/gostate.db
ARTIFACTS_PATH=./data/artifacts

# ─── URL do backend (usada pelo agente para callbacks) ────────────────────────
BACKEND_URL=http://localhost:4000

# ─── Seed de admin padrão (criado na primeira inicialização) ──────────────────
# Se não definidas, usa admin@gostate.dev / admin123 (INSEGURO em produção)
ADMIN_EMAIL=admin@gostate.dev
ADMIN_PASSWORD=change-me-in-production

# ─── Agente padrão (criado na primeira inicialização) ─────────────────────────
# Se não definido, usa token estático previsível (INSEGURO em produção)
# Gere com: node -e "const {v4}=require('uuid'); console.log(v4()+'-'+v4())"
DEFAULT_AGENT_TOKEN=change-me-in-production

# ─── Limpeza de artefatos ──────────────────────────────────────────────────────
# Dias para manter artefatos e logs de execução antes da limpeza automática
ARTIFACT_RETENTION_DAYS=30

